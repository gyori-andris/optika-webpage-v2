---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Nádor Optika – szemüveg, kontaktlencse, látásvizsgálat' } = Astro.props;
---

<!doctype html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} – Nádor Optika</title>
  </head>
  <body>
    <slot />
  </body>
</html>
