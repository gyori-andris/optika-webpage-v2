---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    icon: 'glasses',
    title: 'Személyre szabott szemüvegkészítés',
    desc: 'Hoyalux iD, Essilor Varilux, Zeiss vagy Rodenstock lencsék, hozzá való kerettel, professzionálisan felillesztve. Megszokási garancia az első progresszív szemüveges vásárlóinknak.',
  },
  {
    icon: 'lens',
    title: 'Kontaktlencse forgalmazás',
    desc: 'Igényeknek megfelelő kontaktlencsét kínálunk, a hozzá tartozó tisztító folyadékkal. Új felhasználóknak illesztés-betanítást biztosítunk.',
  },
  {
    icon: 'tool',
    title: 'Szemüveg javítás és beállítás',
    desc: 'Boltunkban vagy műhelyükben a gazdaságosan javítható szemüvegek megjavítását vagy beállítását kínáljuk ügyfeleink részére.',
  },
  {
    icon: 'truck',
    title: 'Helyszíni kiszállás',
    desc: 'Helyszíni kiszállással is biztosítani tudjuk intézményi vagy céges alkalmazottak képernyő előtti munkaszemüveggel történő ellátását.',
  },
];

const testimonials = [
  {
    name: 'Marianna',
    date: '2023.07.10',
    text: 'Még csak a második alkalommal jártam itt, de az a sok jó, amit a kommentelők leírtak, mind igaz. Nekem külön az tetszik, hogy fölöslegesen nem vetetik meg az emberrel az új szemüvegkeretet. Amit most csináltattam szemüveg, egy kb. 3 évvel ezelőtti keretbe került bele és tökéletes. Nagyon köszönöm!',
  },
  {
    name: 'Györgyi A.',
    date: '2023.01.21',
    text: 'Évek óta visszatérő vevő vagyok és mindig jó érzéssel távozom. Pénztárcabarát, nagyon is hozzáértő, barátságos, türelmes optometrista hölgy az eladó. Eddig bármi adódott a szemüveggel, azt ingyen "orvosolta". A Nádor Optika 5★. Visszatérek. Köszönöm!',
  },
  {
    name: 'Tibor S.',
    date: '2022.11.08',
    text: 'Kiváló szakmai tudással rendelkező tulajdonos. Segítőkész és türelmes. Méltányos árakat kínál minőségi termékekkel. Örömmel ajánlom mindenkinek Budapesten, ezt bizton állíthatom.',
  },
];
---

<Layout title="Főoldal" description="Nádor Optika – személyre szabott szemüveg, kontaktlencse és látásvizsgálat Budapest belvárosában.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero__bg" style="background-image:url('/images/uploads/10/1694553162755_2NVIF05G5jPbSfox-1200x700.jpg')"></div>
    <div class="hero__overlay"></div>
    <div class="container hero__content">
      <p class="hero__eyebrow">Egy hely a jó látásért és az elegáns megjelenésért</p>
      <h1 class="hero__title">Nádor Optika</h1>
      <p class="hero__sub">Optikai szalon az Ön igényeihez – Budapest, Arany János utca 16.</p>
      <div class="hero__ctas">
        <a href="/kapcsolat" class="btn btn--hero-primary">Időpontot foglalok</a>
        <a href="/szolgaltatasok" class="btn btn--hero-outline">Szolgáltatásaink</a>
      </div>
    </div>
  </section>

  <!-- Move notice -->
  <section class="notice">
    <div class="container notice__inner">
      <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p><strong>Új helyre költöztünk!</strong> Új üzlethelységünk az Arany János utca 16. udvarában található, a műemlék épület két hatalmas ajtaján belépve szembe.</p>
    </div>
  </section>

  <!-- Services grid -->
  <section class="services-section">
    <div class="container">
      <h2 class="section-title">Szolgáltatások</h2>
      <p class="section-sub">Szemüveg, ami illik hozzád – látási igényednek és stílusodnak megfelelő</p>
      <div class="services-grid">
        {services.map(svc => (
          <article class="service-card">
            <div class="service-card__icon" aria-hidden="true">
              {svc.icon === 'glasses' && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="15" r="4"/><circle cx="18" cy="15" r="4"/><path d="M2 15h4M10 15h4M22 15h-4M10 11V8a2 2 0 012-2h0a2 2 0 012 2v3"/></svg>}
              {svc.icon === 'lens'   && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg>}
              {svc.icon === 'tool'   && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>}
              {svc.icon === 'truck'  && <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>}
            </div>
            <h3 class="service-card__title">{svc.title}</h3>
            <p class="service-card__desc">{svc.desc}</p>
          </article>
        ))}
      </div>
      <div class="services-section__cta">
        <a href="/szolgaltatasok" class="btn btn--outline">Összes szolgáltatás</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials-section">
    <div class="container">
      <h2 class="section-title section-title--light">Mit mondanak rólunk ügyfeleink</h2>
      <div class="testimonials-grid">
        {testimonials.map(t => (
          <blockquote class="testimonial-card">
            <div class="testimonial-card__stars" aria-label="5 csillag">★★★★★</div>
            <p class="testimonial-card__text">"{t.text}"</p>
            <footer class="testimonial-card__footer">
              <strong>{t.name}</strong>
              <time>{t.date}</time>
            </footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA strip -->
  <section class="cta-strip">
    <div class="container cta-strip__inner">
      <div>
        <h2 class="cta-strip__title">Időpontot foglalna?</h2>
        <p class="cta-strip__sub">Hívjon vagy írjon – rendelkezésére állunk!</p>
      </div>
      <div class="cta-strip__actions">
        <a href="tel:+36308582400" class="btn btn--white">+36 30 858 2400</a>
        <a href="/kapcsolat" class="btn btn--white-outline">Kapcsolati űrlap</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 520px;
    display: flex;
    align-items: center;
    color: var(--color-white);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute; inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.03);
  }
  .hero__overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(42,54,122,0.82) 0%, rgba(0,0,0,0.55) 100%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
    padding-block: var(--space-16);
    max-width: 640px;
  }
  .hero__eyebrow {
    font-size: var(--text-small);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(255,255,255,0.75);
    margin: 0 0 var(--space-2);
  }
  .hero__title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: var(--weight-bold);
    color: var(--color-white);
    margin: 0 0 var(--space-3);
    line-height: 1.1;
  }
  .hero__sub {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    margin: 0 0 var(--space-8);
    line-height: 1.6;
  }
  .hero__ctas { display: flex; gap: var(--space-3); flex-wrap: wrap; }

  .btn--hero-primary {
    display: inline-flex; align-items: center;
    padding: var(--space-3) var(--space-8);
    background: var(--color-secondary);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: background var(--transition-fast), transform var(--transition-fast);
  }
  .btn--hero-primary:hover {
    background: color-mix(in srgb, var(--color-secondary) 85%, black);
    color: var(--color-white);
    transform: translateY(-2px);
  }
  .btn--hero-outline {
    display: inline-flex; align-items: center;
    padding: var(--space-3) var(--space-8);
    border: 2px solid rgba(255,255,255,0.7);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: background var(--transition-fast), border-color var(--transition-fast);
  }
  .btn--hero-outline:hover {
    background: rgba(255,255,255,0.1);
    color: var(--color-white);
    border-color: var(--color-white);
  }

  /* Notice */
  .notice {
    background: color-mix(in srgb, var(--color-accent) 12%, white);
    border-left: 4px solid var(--color-accent);
  }
  .notice__inner {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding-block: var(--space-4);
    font-size: var(--text-small);
    color: var(--color-primary);
  }
  .notice__inner svg { flex-shrink: 0; margin-top: 2px; color: var(--color-accent); }

  /* Services */
  .services-section { padding-block: var(--space-16); }
  .section-title {
    text-align: center;
    margin: 0 0 var(--space-2);
  }
  .section-sub {
    text-align: center;
    color: var(--color-text);
    margin: 0 0 var(--space-12);
    max-width: 560px;
    margin-inline: auto;
  }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }
  .service-card {
    background: var(--color-white);
    border: 1px solid var(--color-light);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    box-shadow: var(--shadow-card);
    transition: transform var(--transition-normal), box-shadow var(--transition-normal);
  }
  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgb(42 54 122 / 0.13);
  }
  .service-card__icon {
    width: 52px; height: 52px;
    background: color-mix(in srgb, var(--color-primary) 8%, white);
    border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: var(--space-4);
    color: var(--color-primary);
  }
  .service-card__title {
    font-size: 1rem;
    font-weight: var(--weight-semibold);
    margin: 0 0 var(--space-3);
    color: var(--color-primary);
  }
  .service-card__desc {
    font-size: var(--text-small);
    line-height: 1.7;
    margin: 0;
  }
  .services-section__cta { text-align: center; }
  .btn--outline {
    display: inline-flex; align-items: center;
    padding: var(--space-3) var(--space-8);
    border: 2px solid var(--color-primary);
    color: var(--color-primary);
    border-radius: var(--radius-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .btn--outline:hover {
    background: var(--color-primary);
    color: var(--color-white);
  }

  /* Testimonials */
  .testimonials-section {
    background: var(--color-primary);
    padding-block: var(--space-16);
  }
  .section-title--light { color: var(--color-white); }
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
    margin-top: var(--space-8);
  }
  .testimonial-card {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    margin: 0;
  }
  .testimonial-card__stars {
    color: #FFD700;
    font-size: 1rem;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }
  .testimonial-card__text {
    color: rgba(255,255,255,0.85);
    font-size: var(--text-small);
    line-height: 1.8;
    margin: 0 0 var(--space-4);
    font-style: italic;
  }
  .testimonial-card__footer {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: rgba(255,255,255,0.55);
  }
  .testimonial-card__footer strong { color: rgba(255,255,255,0.85); }

  /* CTA Strip */
  .cta-strip {
    background: var(--color-secondary);
    color: var(--color-white);
    padding-block: var(--space-12);
  }
  .cta-strip__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    flex-wrap: wrap;
  }
  .cta-strip__title {
    color: var(--color-white);
    font-size: 1.5rem;
    margin: 0 0 var(--space-1);
  }
  .cta-strip__sub { margin: 0; color: rgba(255,255,255,0.8); font-size: var(--text-small); }
  .cta-strip__actions { display: flex; gap: var(--space-3); flex-wrap: wrap; }
  .btn--white {
    display: inline-flex; align-items: center;
    padding: var(--space-3) var(--space-6);
    background: var(--color-white);
    color: var(--color-secondary);
    border-radius: var(--radius-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .btn--white:hover { background: rgba(255,255,255,0.9); color: var(--color-secondary); }
  .btn--white-outline {
    display: inline-flex; align-items: center;
    padding: var(--space-3) var(--space-6);
    border: 2px solid rgba(255,255,255,0.7);
    color: var(--color-white);
    border-radius: var(--radius-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: background var(--transition-fast);
  }
  .btn--white-outline:hover { background: rgba(255,255,255,0.1); color: var(--color-white); }
</style>
